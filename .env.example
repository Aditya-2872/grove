# Copy this file to `.env.local` and fill in your values, then restart `npm run dev`.
# `.env.local` is gitignored — it never reaches the repo.

# --- CLIENT (VITE_ prefix = inlined into the browser bundle) ------------------
# From Supabase → Project Settings → API / Data API.
# The anon key is PUBLIC ("publishable") — safe in the browser ONLY because
# Row-Level Security scopes every row to the signed-in user.
# NEVER put the service_role / secret key here (or anywhere in the app).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- SERVER (no VITE_ prefix = NEVER sent to the browser) ---------------------
# Powers /api/ai, so Grove's users get AI without pasting their own key.
# Grove's shared Gemini key. Get one free at https://aistudio.google.com/apikey
# WARNING: never rename this to VITE_GEMINI_API_KEY — that prefix would inline
# it into the public bundle where anyone (and every scraper) can read it.
GEMINI_API_KEY=

# Used by /api/ai to verify the caller is a signed-in Grove user.
# Optional locally: falls back to the VITE_ values above if unset.
SUPABASE_URL=
SUPABASE_ANON_KEY=
